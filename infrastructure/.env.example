# =====================
# PostgreSQL
# =====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=foodgroup
POSTGRES_USER=foodgroup
POSTGRES_PASSWORD=change_me_strong_password

# =====================
# Redis
# =====================
REDIS_HOST=localhost
REDIS_PORT=6379

# =====================
# 암호화 (AES-256, 32바이트 hex)
# =====================
ENCRYPTION_KEY=change_me_64hex_chars_32bytes_key_here_00000000000000000000

# =====================
# AWS
# =====================
AWS_REGION=ap-northeast-2
S3_BACKUP_BUCKET=your-foodgroup-backup-bucket
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# =====================
# CloudFront
# =====================
CLOUDFRONT_DOMAIN=xxxxxxxxxx.cloudfront.net

# =====================
# Spring 프로파일
# =====================
SPRING_PROFILES_ACTIVE=prod

{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_BASE_URL": "http://192.168.1.100:8080"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_BASE_URL": "https://api.foodgroup.example.com"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "API_BASE_URL": "https://api.foodgroup.example.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
